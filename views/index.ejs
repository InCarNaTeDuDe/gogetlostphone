<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>FCM Camera Control</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body class="bg-light">
  <!DOCTYPE html>

  <html lang="en">

  <head>
    <meta charset="UTF-8" />
    <title>Maska Magic - Device Recovery</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
      body {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .control-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(10px);
        border-radius: 18px;
        padding: 40px;
        width: 420px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      }

      .action-btn {
        font-size: 20px;
        padding: 14px;
        border-radius: 12px;
        margin-top: 15px;
      }

      .title-icon {
        font-size: 40px;
      }

      .footer-note {
        font-size: 13px;
        opacity: 0.7;
        margin-top: 20px;
      }
    </style>

  </head>

  <body>

    <div class="control-card text-center">

      <div class="title-icon mb-2">📱</div>
      <h3 class="mb-1">Maska Magic</h3>
      <p class="text-light mb-4">Lost your phone? Trigger actions remotely.</p>

      <form action="/trigger-capture" method="POST">
        <button type="submit" class="btn btn-success w-100 action-btn">
          📸 Capture Photo
        </button>
      </form>

      <form action="/trigger-alarm" method="POST">
        <button type="submit" class="btn btn-warning w-100 action-btn">
          🔊 Play Loud Alarm
        </button>
      </form>

      <form action="/trigger-location" method="POST">
        <button type="submit" class="btn btn-info w-100 action-btn">
          📍 Get Device Location
        </button>
      </form>

      <form action="/trigger-lock" method="POST">
        <button type="submit" class="btn btn-danger w-100 action-btn">
          🔒 Lock Device
        </button>
      </form>

      <% if (response) { %>

        <div class="mt-4">

          <% if (response.error) { %>

            <div class="alert alert-danger text-start">
              ❌ <%= JSON.stringify(response.error, null, 2) %>
            </div>

            <% } else if (response.success) { %>

              <div class="alert alert-success text-start">
                ✅ Command sent successfully
                <pre><%= JSON.stringify(response.result, null, 2) %></pre>
              </div>

              <% } %>

        </div>

        <% } %>

          <div class="footer-note">
            Commands will be delivered when the device is connected to the internet.
          </div>


    </div>

  </body>

  </html>

</body>

</html>
